# SpiceLab Docker 环境配置
# 复制此文件到 .env 并根据需要修改

# =============================================================================
# 数据库配置
# =============================================================================
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=spicelab

# =============================================================================
# 后端配置
# =============================================================================
SPRING_PROFILES_ACTIVE=prod
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root123
DB_NAME=spicelab

# =============================================================================
# JWT 配置 (生产环境请修改!)
# =============================================================================
JWT_SECRET=your-secret-key-change-in-production

# =============================================================================
# 前端配置
# =============================================================================
VITE_APP_TITLE=SpiceLab
VITE_API_URL=http://localhost:8080
